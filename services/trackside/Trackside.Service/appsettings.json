{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Trackside": {
    "Http": {
      "ListenUrl": "http://127.0.0.1:8877",
      "PublicBaseUrl": "http://127.0.0.1:8877"
    },
    "Source": {
      "Mode": "Fixture",
      "FixturePath": "Fixtures/scoring-leaderboard-practice.json",
      "DriverAliases": {
        "Setup1": "Maya",
        "Setup2": "Noah"
      },
      "SharedMemory": {
        "AutoDiscover": true,
        "DedicatedServerProcessNames": [
          "rFactor2 Dedicated.exe",
          "Dedicated.exe"
        ],
        "MultipleScoringMapPolicy": "RequireExplicitSelection",
        "ScoringPollHz": 10.0,
        "Telemetry": {
          "Enabled": false,
          "PollHz": 100.0
        }
      }
    },
    "LiveSession": {
      "PublishIntervalSeconds": 1.0
    },
    "Cors": {
      "AllowedOrigins": [
        "http://localhost:5173",
        "http://127.0.0.1:5173"
      ]
    },
    "Deployment": {
      "InstallMode": "Development",
      "ServiceName": "Trackside",
      "TrayAutostartName": "Trackside Tray"
    },
    "Updates": {
      "Status": "NotConfigured",
      "Channel": "local",
      "MinimumCompatibleVersion": "0.1.0"
    }
  }
}
