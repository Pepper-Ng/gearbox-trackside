{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Trackside": {
    "Http": {
      "ListenUrl": "http://127.0.0.1:8877",
      "PublicBaseUrl": "http://127.0.0.1:8877"
    },
    "Source": {
      "Mode": "Fixture",
      "FixturePath": "Fixtures/mock-live-session.json"
    },
    "LiveSession": {
      "PublishIntervalSeconds": 1.0
    },
    "Cors": {
      "AllowedOrigins": [
        "http://localhost:5173",
        "http://127.0.0.1:5173"
      ]
    },
    "Tray": {
      "Enabled": true,
      "Tooltip": "Trackside Host",
      "BalloonTitle": "Trackside is running",
      "BalloonMessage": "Use the tray menu to open the kiosk, health endpoint, or stop the host.",
      "MenuItems": [
        {
          "Text": "Open Kiosk",
          "Action": "OpenUrl",
          "Route": "/"
        },
        {
          "Text": "Open Health",
          "Action": "OpenUrl",
          "Route": "/api/health"
        },
        {
          "Text": "Open Client Config",
          "Action": "OpenUrl",
          "Route": "/api/configuration/client"
        },
        {
          "Action": "Separator"
        },
        {
          "Text": "Exit Trackside",
          "Action": "Exit"
        }
      ]
    }
  }
}
